# server
NODE_ENV=production
PORT=3000
PUBLIC_ORIGIN=https://swissbakery.com.au

# db - provision via cPanel → MySQL Databases, then paste DSN here
DATABASE_URL="mysql://USER:PASS@localhost:3306/DBNAME"

# auth - ADMIN_PASSWORD_HASH is an argon2 hash. Generate with: npm run hash-password
ADMIN_EMAIL=owner@swissbakery.com.au
ADMIN_PASSWORD_HASH=

# JWT_SECRET and JWT_REFRESH_SECRET must each be >=32 random bytes, base64.
# Generate each with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# cors - comma-separated allow-list
ALLOWED_ORIGINS=https://swissbakery.com.au,https://www.swissbakery.com.au
