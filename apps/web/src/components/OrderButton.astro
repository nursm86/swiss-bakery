---
// Renders a GloriaFood order trigger. The GloriaFood script (loaded once in
// Layout.astro) scans for any .glf-button element and wires it to open the
// ordering widget. We bake default cuid/ruid at build time; admin edits
// trigger a rebuild to take effect.
import { DEFAULT_SETTINGS } from "../lib/seed";

interface Props {
  label?: string;
  variant?: "primary" | "outline" | "gold";
  class?: string;
}

const { label = "See Menu & Order", variant = "primary", class: klass = "" } = Astro.props;
const s = DEFAULT_SETTINGS;
const styleMap = {
  primary: "btn-primary",
  outline: "btn-outline",
  gold: "btn-primary",
} as const;
const styleClass = styleMap[variant];
const extraStyle =
  variant === "gold"
    ? "background:var(--color-gold);color:var(--color-navy);"
    : "";
---
{s.gloriafoodCuid && s.gloriafoodRuid && (
  <span
    class:list={["glf-button", styleClass, klass]}
    data-glf-cuid={s.gloriafoodCuid}
    data-glf-ruid={s.gloriafoodRuid}
    role="button"
    tabindex="0"
    style={`cursor:pointer;${extraStyle}`}
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M3 6h18l-2 13H5L3 6z M8 6V4a4 4 0 0 1 8 0v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    {label}
  </span>
)}
