---
import { featured } from "../lib/seed";
import ProductCard from "./ProductCard.astro";
---
<section id="featured" class="py-14 sm:py-20">
  <div class="container-x">
    <div class="flex items-end justify-between gap-4 flex-wrap">
      <div>
        <span class="chip chip-cream mb-3">Fresh today</span>
        <h2 class="section-title text-3xl sm:text-4xl mt-2">House favourites at Swiss Bakery-Minto</h2>
        <p class="mt-3 text-[color:var(--color-muted)] max-w-xl">
          What regulars in Minto order first. Availability rotates through the day — drop by early for the patties, late for the firni.
        </p>
      </div>
      <a href="#menu" class="text-sm font-semibold text-[color:var(--color-navy)] underline decoration-[color:var(--color-gold)] decoration-2 underline-offset-4 hover:opacity-70">
        See full menu →
      </a>
    </div>
    <div id="featured-scroll" class="mt-8 flex gap-4 overflow-x-auto pb-4 -mx-5 px-5 scroll-x">
      {featured.map((p) => <ProductCard product={p} size="sm" />)}
    </div>
  </div>
</section>
