---
import { DEFAULT_SETTINGS } from "../lib/seed";
---
<section id="about" class="py-14 sm:py-20">
  <div class="container-x grid md:grid-cols-2 gap-10 lg:gap-16 items-center">
    <div class="relative aspect-[4/5] rounded-2xl overflow-hidden bg-[color:var(--color-cream-200)] border border-[color:var(--color-cream-200)]">
      <div class="absolute inset-0 hero-placeholder"></div>
      <div class="absolute inset-0 grid place-items-center text-center px-8">
        <div>
          <img src="/swiss_logo.png" alt="" width="96" height="96" class="mx-auto opacity-80" />
          <p class="mt-5 font-[family-name:var(--font-display)] text-xl text-[color:var(--color-navy)]">
            Our story
          </p>
          <p class="mt-2 text-sm text-[color:var(--color-muted)] max-w-xs mx-auto">
            Shopfront photography coming soon - owner-supplied.
          </p>
        </div>
      </div>
    </div>
    <div>
      <span class="chip chip-cream">About us</span>
      <h2 class="section-title text-3xl sm:text-4xl mt-3">Swiss precision, Bengali soul</h2>
      <p id="about-text" class="mt-5 text-[color:var(--color-navy)]/85 leading-relaxed text-[0.97rem] sm:text-base">
        {DEFAULT_SETTINGS.aboutText}
      </p>
      <ul class="mt-7 grid grid-cols-2 gap-4 text-sm">
        <li class="flex items-start gap-3">
          <span class="swiss-cross mt-0.5" style="--s:26px"></span>
          <div>
            <p class="font-semibold text-[color:var(--color-navy)]">Baked daily</p>
            <p class="text-[color:var(--color-muted)]">On-site ovens from dawn</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="swiss-cross mt-0.5" style="--s:26px"></span>
          <div>
            <p class="font-semibold text-[color:var(--color-navy)]">Halal kitchen</p>
            <p class="text-[color:var(--color-muted)]">Separate meat + veg lines</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="swiss-cross mt-0.5" style="--s:26px"></span>
          <div>
            <p class="font-semibold text-[color:var(--color-navy)]">Small batch</p>
            <p class="text-[color:var(--color-muted)]">Sweets by the kilo, fresh</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="swiss-cross mt-0.5" style="--s:26px"></span>
          <div>
            <p class="font-semibold text-[color:var(--color-navy)]">Catering ready</p>
            <p class="text-[color:var(--color-muted)]">Trays, boxes, large orders</p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>
<script>
  fetch("/api/settings")
    .then((r) => (r.ok ? r.json() : null))
    .then((data) => {
      const about = data?.settings?.aboutText;
      const el = document.getElementById("about-text");
      if (about && el) el.textContent = about;
    })
    .catch(() => {});
</script>
