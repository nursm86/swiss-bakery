---
import { DEFAULT_SETTINGS } from "../lib/seed";
const year = new Date().getFullYear();
const s = DEFAULT_SETTINGS;
---
<footer class="bg-[color:var(--color-ink)] text-white/70 text-sm">
  <div class="container-x py-12 grid gap-8 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-3">
        <img src="/swiss_logo.png" alt="" width="44" height="44" class="rounded-full" />
        <span class="font-[family-name:var(--font-display)] text-xl text-white">Swiss <span class="swiss-cross inline-block align-middle" style="--s:14px;margin:0 4px 2px"></span> Bakery</span>
      </div>
      <p class="mt-4 max-w-md text-white/60 leading-relaxed">
        Handcrafted pastries and traditional Bengali sweets - baked on-site in Minto. Walk-ins, phone orders and catering trays all welcome.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a id="f-facebook" href={s.facebookUrl || "#"} target="_blank" rel="noopener" class="w-9 h-9 grid place-items-center rounded-full border border-white/20 hover:border-[color:var(--color-gold)] hover:text-[color:var(--color-gold)] transition" aria-label="Facebook">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 22v-9h3l.5-4H13V6.6c0-1.1.4-1.9 2-1.9h1.6V1.1C16.3 1 15.4.9 14.3.9c-2.8 0-4.8 1.7-4.8 4.9V9H7v4h2.5v9H13z"/></svg>
        </a>
        <a id="f-instagram" href={s.instagramUrl || "#"} target="_blank" rel="noopener" class="w-9 h-9 grid place-items-center rounded-full border border-white/20 hover:border-[color:var(--color-gold)] hover:text-[color:var(--color-gold)] transition" aria-label="Instagram">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
        </a>
      </div>
    </div>
    <div>
      <h4 class="text-white text-sm font-semibold uppercase tracking-[0.18em]">Menu</h4>
      <ul class="mt-3 space-y-2">
        <li><a href="#cat-savoury" class="hover:text-[color:var(--color-gold)]">Savoury</a></li>
        <li><a href="#cat-bakery" class="hover:text-[color:var(--color-gold)]">Bakery</a></li>
        <li><a href="#cat-sweets" class="hover:text-[color:var(--color-gold)]">Sweets</a></li>
        <li><a href="#cat-beverages" class="hover:text-[color:var(--color-gold)]">Beverages</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-white text-sm font-semibold uppercase tracking-[0.18em]">Contact</h4>
      <ul class="mt-3 space-y-2">
        <li id="f-address">{s.address}</li>
        <li><a id="f-phone" href={s.phoneHref} class="hover:text-[color:var(--color-gold)]">{s.phone}</a></li>
        <li><a id="f-email" href={s.emailHref} class="hover:text-[color:var(--color-gold)]">{s.email}</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="container-x py-5 flex flex-col md:flex-row gap-3 justify-between items-start md:items-center text-xs text-white/50">
      <span>© {year} Swiss Bakery · All rights reserved.</span>
      <div class="flex flex-wrap gap-x-5 gap-y-1 items-center">
        <a href="/terms" class="hover:text-[color:var(--color-gold)]">Terms &amp; Conditions</a>
        <span class="hidden md:inline">·</span>
        <span>Some product imagery courtesy Wikimedia Commons contributors, used under CC-BY-SA 4.0.</span>
      </div>
    </div>
  </div>
</footer>
<script>
  fetch("/api/settings")
    .then((r) => (r.ok ? r.json() : null))
    .then((data) => {
      const s = data?.settings;
      if (!s) return;
      const byId = (id: string) => document.getElementById(id);
      if (s.address && byId("f-address")) byId("f-address")!.textContent = s.address;
      if (s.phone && byId("f-phone")) {
        const el = byId("f-phone") as HTMLAnchorElement;
        el.textContent = s.phone;
        el.href = `tel:${s.phone.replace(/\s+/g, "")}`;
      }
      if (s.email && byId("f-email")) {
        const el = byId("f-email") as HTMLAnchorElement;
        el.textContent = s.email;
        el.href = `mailto:${s.email}`;
      }
      const fb = byId("f-facebook") as HTMLAnchorElement | null;
      if (fb) {
        if (s.facebookUrl) fb.href = s.facebookUrl;
        else fb.style.display = "none";
      }
      const ig = byId("f-instagram") as HTMLAnchorElement | null;
      if (ig) {
        if (s.instagramUrl) ig.href = s.instagramUrl;
        else ig.style.display = "none";
      }
    })
    .catch(() => {});
</script>
