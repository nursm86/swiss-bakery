---
import { DEFAULT_SETTINGS } from "../lib/seed";
import OrderButton from "./OrderButton.astro";
const s = DEFAULT_SETTINGS;
---
<section id="contact" class="py-14 sm:py-20 bg-[color:var(--color-charcoal)] text-white relative overflow-hidden">
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background:radial-gradient(circle at 14% 18%, rgba(225,29,39,0.14), transparent 55%), radial-gradient(circle at 86% 82%, rgba(243,112,32,0.16), transparent 55%);"></div>
  <div class="container-x grid lg:grid-cols-2 gap-10 relative">
    <div>
      <span class="chip chip-red">Find us</span>
      <h2 class="mt-4 font-[family-name:var(--font-display)] text-3xl sm:text-4xl text-white">Visit Swiss Bakery-Minto in Minto, NSW</h2>
      <p class="mt-3 text-white/70 max-w-lg">
        Shop 3/12 Minto Rd — five minutes from Minto station. Parking out front. Walk-ins welcome; phone ahead for large orders, catering trays and custom sweets at Swiss Bakery-Minto.
      </p>

      <dl class="mt-8 space-y-5">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 grid place-items-center rounded-full bg-white/10 shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 21s-7-7.58-7-12a7 7 0 0 1 14 0c0 4.42-7 12-7 12z" stroke="currentColor" stroke-width="1.6"/>
              <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.6"/>
            </svg>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-orange)]">Address</dt>
            <dd id="c-address" class="mt-1 text-white">{s.address}</dd>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 grid place-items-center rounded-full bg-white/10 shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.1 4.18 2 2 0 0 1 4.09 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-orange)]">Phone</dt>
            <dd class="mt-1"><a id="c-phone" href={s.phoneHref} class="hover:text-[color:var(--color-orange)] transition">{s.phone}</a></dd>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 grid place-items-center rounded-full bg-white/10 shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M4 4h16v16H4z M4 4l8 8 8-8" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-orange)]">Email</dt>
            <dd class="mt-1"><a id="c-email" href={s.emailHref} class="hover:text-[color:var(--color-orange)] transition">{s.email}</a></dd>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 grid place-items-center rounded-full bg-white/10 shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/>
              <path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-orange)]">Hours</dt>
            <dd id="c-hours" class="mt-1 whitespace-pre-line">{s.hours}</dd>
          </div>
        </div>
      </dl>

      <div class="mt-8 flex flex-wrap gap-3">
        <OrderButton label="Order Online" variant="gold" />
        <a href={s.phoneHref} class="btn-outline-light">Call shop</a>
        <a href={s.mapEmbedUrl.replace("&output=embed", "")} target="_blank" rel="noopener" class="btn-outline-light">Open in Maps ↗</a>
      </div>
    </div>

    <div class="rounded-2xl overflow-hidden border border-white/10 min-h-[340px] lg:min-h-[460px] shadow-xl">
      <iframe
        id="c-map"
        src={s.mapEmbedUrl}
        title="Swiss Bakery location"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="w-full h-full min-h-[340px] lg:min-h-[460px]"
      ></iframe>
    </div>
  </div>

</section>
<script>
  fetch("/api/settings")
    .then((r) => (r.ok ? r.json() : null))
    .then((data) => {
      const s = data?.settings;
      if (!s) return;
      const byId = (id: string) => document.getElementById(id);
      if (s.address && byId("c-address")) byId("c-address")!.textContent = s.address;
      if (s.phone && byId("c-phone")) {
        const el = byId("c-phone") as HTMLAnchorElement;
        el.textContent = s.phone;
        el.href = `tel:${s.phone.replace(/\s+/g, "")}`;
      }
      if (s.email && byId("c-email")) {
        const el = byId("c-email") as HTMLAnchorElement;
        el.textContent = s.email;
        el.href = `mailto:${s.email}`;
      }
      if (s.hours && byId("c-hours")) byId("c-hours")!.textContent = s.hours;
      if (s.mapEmbedUrl && byId("c-map")) (byId("c-map") as HTMLIFrameElement).src = s.mapEmbedUrl;

      // Apply admin-edited GloriaFood IDs to every .glf-button on the page.
      // (The widget script reads these attributes on load.)
      if (s.gloriafoodCuid && s.gloriafoodRuid) {
        document.querySelectorAll<HTMLElement>(".glf-button").forEach((el) => {
          el.dataset.glfCuid = s.gloriafoodCuid;
          el.dataset.glfRuid = s.gloriafoodRuid;
        });
      }
    })
    .catch(() => {});
</script>
