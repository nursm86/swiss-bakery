---
import { DEFAULT_HERO } from "../lib/seed";
const h = DEFAULT_HERO;
---
<section id="top" class="relative overflow-hidden">
  <div id="hero-root" class="relative hero-placeholder">
    <div class="container-x relative py-16 sm:py-24 lg:py-32 grid place-items-center text-center">
      <img src="/swiss_logo.png" alt="Swiss Bakery emblem" width="120" height="120" class="mb-6 rounded-full shadow-md" />
      <h1 id="hero-heading" class="font-[family-name:var(--font-display)] text-4xl sm:text-5xl lg:text-6xl font-semibold text-[color:var(--color-navy)] max-w-3xl leading-tight reveal in">
        {h.heading}
      </h1>
      <p id="hero-subheading" class="mt-5 text-base sm:text-lg text-[color:var(--color-navy)]/80 italic max-w-2xl reveal in" style="font-family:var(--font-display)">
        {h.subheading}
      </p>
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <a id="hero-cta" href={h.ctaHref} class="btn-outline">{h.ctaLabel}</a>
        <a href="#contact" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.1 4.18 2 2 0 0 1 4.09 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Call · Visit
        </a>
      </div>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-3 text-xs uppercase tracking-[0.18em] text-[color:var(--color-navy)]/60">
        <span class="chip chip-cream">Baked on-site</span>
        <span class="chip chip-cream">Halal kitchen</span>
        <span class="chip chip-cream">Open 6 days</span>
      </div>
    </div>
  </div>
</section>
<script>
  type Banner = {
    heading: string;
    subheading: string | null;
    ctaLabel: string | null;
    ctaHref: string | null;
    imagePath: string | null;
  };
  fetch("/api/hero")
    .then((r) => (r.ok ? r.json() : null))
    .then((data) => {
      const b = (data?.banners ?? [])[0] as Banner | undefined;
      if (!b) return;
      const heading = document.getElementById("hero-heading");
      const sub = document.getElementById("hero-subheading");
      const cta = document.getElementById("hero-cta") as HTMLAnchorElement | null;
      const root = document.getElementById("hero-root");
      if (heading && b.heading) heading.textContent = b.heading;
      if (sub && b.subheading) sub.textContent = b.subheading;
      if (cta) {
        if (b.ctaLabel) cta.textContent = b.ctaLabel;
        if (b.ctaHref) cta.href = b.ctaHref;
      }
      if (root && b.imagePath) {
        root.classList.remove("hero-placeholder");
        root.style.backgroundImage = `linear-gradient(rgba(246,239,224,0.4), rgba(246,239,224,0.85)), url('${b.imagePath}')`;
        root.style.backgroundSize = "cover";
        root.style.backgroundPosition = "center";
      }
    })
    .catch(() => {});
</script>
