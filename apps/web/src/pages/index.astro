---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import NoticeStrip from "../components/NoticeStrip.astro";
import Hero from "../components/Hero.astro";
import Featured from "../components/Featured.astro";
import Menu from "../components/Menu.astro";
import About from "../components/About.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
---
<Layout>
  <NoticeStrip />
  <Nav />
  <h1 class="sr-only">Swiss Bakery-Minto · Swiss patisserie and Bengali sweets in Minto, NSW</h1>
  <main>
    <Hero />
    <Featured />
    <Menu />
    <About />
    <Contact />
  </main>
  <Footer />
  <script>
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in");
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12 },
    );
    document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

    // Live-refresh product grid on initial load if API has newer data.
    type ApiProduct = {
      slug: string;
      name: string;
      category: string;
      priceCents: number | null;
      unit: string;
      description: string | null;
      imagePath: string | null;
      isFeatured: boolean;
      isActive: boolean;
      sortOrder: number;
    };
    const formatPrice = (p: ApiProduct) =>
      p.priceCents == null ? "Visit shop" : `$${(p.priceCents / 100).toFixed(2)}`;

    fetch("/api/products")
      .then((r) => (r.ok ? r.json() : null))
      .then((data) => {
        if (!data?.products) return;
        const map = new Map<string, ApiProduct>(
          data.products.map((p: ApiProduct) => [p.slug, p]),
        );
        document.querySelectorAll<HTMLElement>("article.card[data-slug]").forEach((card) => {
          const slug = card.dataset.slug!;
          const p = map.get(slug);
          if (!p) {
            card.remove();
            return;
          }
          if (!p.isActive) {
            card.remove();
            return;
          }
          const title = card.querySelector("h3");
          if (title) title.textContent = p.name;
          const desc = card.querySelector("p");
          if (desc && p.description) desc.textContent = p.description;
          const price = card.querySelector(".p-4 > div span:first-child");
          if (price) price.textContent = formatPrice(p);
          const img = card.querySelector("img");
          if (img && p.imagePath) {
            (img as HTMLImageElement).src = p.imagePath;
            (img as HTMLImageElement).alt = p.name;
          }
        });
      })
      .catch(() => {});
  </script>
</Layout>
