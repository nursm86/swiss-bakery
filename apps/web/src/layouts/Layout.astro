---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Swiss Bakery · Minto NSW · Swiss patisserie & Bengali sweets",
  description = "Handcrafted European pastries and traditional Bengali sweets, baked fresh daily at Shop 3/12 Minto Rd, Minto NSW 2566.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content="#1a2a4f" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Bakery",
        name: "Swiss Bakery",
        image: new URL("/swiss_logo.png", Astro.site).toString(),
        url: Astro.site?.toString(),
        telephone: "+61 0452 626 232",
        email: "contact@swissbakery.com.au",
        priceRange: "$",
        address: {
          "@type": "PostalAddress",
          streetAddress: "Shop 3/12 Minto Rd",
          addressLocality: "Minto",
          addressRegion: "NSW",
          postalCode: "2566",
          addressCountry: "AU",
        },
      })}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
