---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Swiss Bakery-Minto · Swiss patisserie & Bengali sweets · Minto NSW · Order online",
  description = "Order online for pickup from Swiss Bakery-Minto. Handcrafted European patisserie, fresh patties, rolls and samosas, and traditional Bengali sweets — baked daily at Shop 3/12 Minto Rd, Minto NSW 2566.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const logoUrl = new URL("/swiss_logo.png", Astro.site).toString();
const menuUrl = new URL("/#menu", Astro.site).toString();
// Build marker — changes on every `astro build`, so we can confirm in the
// browser console that a deploy has actually landed on the live site.
const buildStamp = new Date().toISOString().replace("T", " ").slice(0, 19) + " UTC";
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content="#1a2a4f" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Bakery",
        "@id": `${Astro.site?.toString() ?? ""}#bakery`,
        name: "Swiss Bakery-Minto",
        alternateName: "Swiss Bakery",
        image: logoUrl,
        logo: logoUrl,
        url: Astro.site?.toString(),
        telephone: "+61 0452 626 232",
        email: "contact@swissbakery.com.au",
        priceRange: "$",
        servesCuisine: ["Bakery", "Patisserie", "Bengali", "Swiss"],
        menu: menuUrl,
        hasMenu: menuUrl,
        acceptsReservations: "False",
        paymentAccepted: "Cash, Credit Card, Contactless",
        currenciesAccepted: "AUD",
        address: {
          "@type": "PostalAddress",
          streetAddress: "Shop 3/12 Minto Rd",
          addressLocality: "Minto",
          addressRegion: "NSW",
          postalCode: "2566",
          addressCountry: "AU",
        },
        geo: {
          "@type": "GeoCoordinates",
          latitude: -33.9833,
          longitude: 150.8500,
        },
        hasMap: "https://www.google.com/maps?q=Shop+3%2F12+Minto+Rd%2C+Minto+NSW+2566",
        openingHoursSpecification: [
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
            opens: "08:00",
            closes: "20:00",
          },
        ],
        sameAs: ["https://www.facebook.com/profile.php?id=61588443717316"],
      })}
    />
  </head>
  <body>
    <!-- Build marker — visible in DevTools console on every page load.
         If the stamp doesn't change after a deploy, the new build hasn't
         reached the browser (check Cloudflare cache or Passenger restart). -->
    <script is:inline define:vars={{ buildStamp }}>
      console.log(
        "%c Swiss Bakery %c build: " + buildStamp + " ",
        "background:#1a2a4f;color:#c89a2b;padding:2px 6px;border-radius:3px 0 0 3px;font-weight:bold",
        "background:#c89a2b;color:#1a2a4f;padding:2px 6px;border-radius:0 3px 3px 0;font-weight:bold",
      );
    </script>
    <slot />
    <!-- GloriaFood ordering widget: scans the page for .glf-button elements
         and wires them to open the order popup. -->
    <script src="https://www.fbgcdn.com/embedder/js/ewm2.js" defer async></script>
  </body>
</html>
