{
  "name": "swiss-bakery",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "npm run dev --workspace=@swiss-bakery/api",
    "dev:web": "npm run dev --workspace=@swiss-bakery/web",
    "build": "cd apps/web && npm run build && cd ../api && npm run build",
    "build:web": "cd apps/web && npm run build",
    "build:api": "cd apps/api && npm run build",
    "cpanel:build": "node scripts/cpanel-build.mjs",
    "start": "node apps/api/dist/index.js",
    "start:local": "node --env-file=.env apps/api/dist/index.js",
    "deploy:prisma": "cd apps/api && npm run prisma:deploy && npm run prisma:seed",
    "prisma:deploy": "cd apps/api && npm run prisma:deploy",
    "prisma:migrate": "cd apps/api && npm run prisma:migrate",
    "prisma:seed": "cd apps/api && npm run prisma:seed",
    "hash-password": "cd apps/api && npm run hash-password"
  }
}
