{
  "name": "swiss-bakery",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "apps/api/dist/index.js",
  "scripts": {
    "dev:api": "cd apps/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "build": "node scripts/cpanel-build.mjs",
    "cpanel:build": "node scripts/cpanel-build.mjs",
    "cpanel:postinstall": "node scripts/cpanel-postinstall.mjs",
    "start": "node apps/api/dist/index.js",
    "start:local": "node --env-file=.env apps/api/dist/index.js",
    "deploy:prisma": "prisma migrate deploy --schema apps/api/prisma/schema.prisma && node --import tsx apps/api/prisma/seed.ts",
    "prisma:deploy": "prisma migrate deploy --schema apps/api/prisma/schema.prisma",
    "prisma:seed": "node --import tsx apps/api/prisma/seed.ts",
    "hash-password": "node --import tsx apps/api/scripts/hash-password.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prisma": "^6.1.0",
    "sharp": "^0.34.0",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.2"
  }
}
